# Copy to `.env` in the repository root (optional — defaults match local dev).
# Same variable names are used by `docker compose` (see README § Docker).

# Backend (apps/backend) + Socket.IO CORS — browser origin for the UI
PORT=5000
CLIENT_URL=http://localhost:5173

# Simulator (apps/simulator) — where to POST telemetry
# Local npm: http://localhost:5000  ·  Docker Compose: http://backend:5000 (set automatically in compose file)
BACKEND_URL=http://localhost:5000
SIM_INTERVAL_MS=1000
LOCOMOTIVE_TYPE=KZ8A

# Frontend — baked at `vite build` / Docker image build (browser calls host-published ports)
VITE_API_URL=http://localhost:5000
VITE_WS_URL=http://localhost:5000

# HK-034 — show scenario selector + dev telemetry for non-admin (hackathon demo). Omit or false = operator-only UI.
# VITE_DEMO_CONTROLS=true

# HK-021 — Python ML risk service (optional). Backend proxies GET /api/ml/risk → POST {ML_RISK_URL}/predict
ML_RISK_URL=http://127.0.0.1:8001
